<Window x:Class="crochet_store.SupMgnt"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Supplier Management - Crochet Craft Store"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Window.Resources>
        <!-- Sidebar Button Style -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.08" 
                                                BlurRadius="8" ShadowDepth="2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"
                                              Margin="10,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#667EEA"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#667EEA"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5568D3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#95A5A6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Style -->
        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="25"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.08" 
                                    BlurRadius="15" ShadowDepth="3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#DFE6E9"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#667EEA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern DataGrid Style -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#F8F9FA"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" Background="#2C3E50">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="20,30,20,30">
                    <TextBlock Text="🏭 Suppliers" 
                             FontSize="24" 
                             FontWeight="Bold" 
                             Foreground="#FFFFFF"
                             HorizontalAlignment="Center"/>
                    <TextBlock Text="Management Panel" 
                             FontSize="13" 
                             Foreground="#95A5A6"
                             HorizontalAlignment="Center"
                             Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Navigation Menu -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15,0,15,15">
                        <TextBlock Text="ACTIONS" 
                                   FontSize="11" 
                                   Foreground="#7F8C8D" 
                                   FontWeight="Bold"
                                   Margin="10,0,0,10"/>

                        <Button Style="{StaticResource SidebarButton}" 
                                Click="ShowAddSupplier">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="➕" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Add Supplier"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButton}" 
                                Click="ShowUpdateSupplier">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✏️" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Update Supplier"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButton}" 
                                Click="DeleteSupplier_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑️" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Delete Supplier"/>
                            </StackPanel>
                        </Button>

                        <Separator Background="#34495E" Margin="0,10,0,20"/>

                        <TextBlock Text="REPORTS" 
                                   FontSize="11" 
                                   Foreground="#7F8C8D" 
                                   FontWeight="Bold"
                                   Margin="10,0,0,10"/>

                        <Button Style="{StaticResource SidebarButton}" Click="AllSuppliers_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="All Suppliers"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButton}" Click="SuppliersByRegion_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗺️" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="By Region"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButton}" Click="ShipmentHistory_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Shipment History"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <StackPanel Grid.Row="2" Margin="15,15,15,25">
                    <Separator Background="#34495E" Margin="0,0,0,15"/>
                    <Button Content="⬅ Back to Dashboard"
                            Style="{StaticResource SecondaryButton}"
                            Click="Exit_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- RIGHT CONTENT AREA -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header Section -->
            <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock x:Name="txtPageTitle" 
                               Text="Supplier Management Dashboard" 
                               FontSize="26" 
                               FontWeight="Bold" 
                               Foreground="#2C3E50"/>
                    <TextBlock x:Name="txtPageSubtitle"
                               Text="Select an action from the sidebar to get started" 
                               FontSize="13" 
                               Foreground="#7F8C8D"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Main Content Panel -->
            <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                <Grid>
                    <!-- ADD / UPDATE FORM -->
                    <ScrollViewer x:Name="SupplierForm" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                            <TextBlock Text="Supplier ID" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtSupplierId" Style="{StaticResource ModernTextBox}" IsReadOnly="True" Background="#F0F0F0"/>

                            <TextBlock Text="Supplier Name *" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtSupplierName" Style="{StaticResource ModernTextBox}"/>

                            <TextBlock Text="Contact Number *" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtContact" Style="{StaticResource ModernTextBox}" MaxLength="20"/>

                            <TextBlock Text="Email Address *" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtEmail" Style="{StaticResource ModernTextBox}"/>

                            <TextBlock Text="Address *" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtAddress" Style="{StaticResource ModernTextBox}" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>

                            <TextBlock Text="Region *" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <ComboBox x:Name="cmbRegion" FontSize="13" Padding="12,10" BorderBrush="#DFE6E9" BorderThickness="2" Margin="0,5,0,15">
                                <ComboBoxItem Content="Punjab"/>
                                <ComboBoxItem Content="Sindh"/>
                                <ComboBoxItem Content="Khyber Pakhtunkhwa"/>
                                <ComboBoxItem Content="Balochistan"/>
                                <ComboBoxItem Content="Islamabad"/>
                                <ComboBoxItem Content="Gilgit-Baltistan"/>
                                <ComboBoxItem Content="Azad Kashmir"/>
                            </ComboBox>

                            <TextBlock Text="* Required fields" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="btnSave" Content="Save Supplier" Style="{StaticResource PrimaryButton}" Margin="0,10,10,0" Width="150" Click="SaveSupplier_Click"/>
                                <Button Content="Clear Form" Style="{StaticResource SecondaryButton}" Margin="0,10,0,0" Width="150" Click="ClearForm_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- DATA GRID -->
                    <DataGrid x:Name="dgSuppliers" Visibility="Collapsed" Style="{StaticResource ModernDataGrid}" FontSize="13"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
