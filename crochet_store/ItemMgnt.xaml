<Window x:Class="crochet_store.ItemMgnt"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Item Management - Crochet Craft Store"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Window.Resources>
        <!-- Sidebar Button Style -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                BorderThickness="0">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.08" 
                                                BlurRadius="8" ShadowDepth="2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Left" 
                                            VerticalAlignment="Center"
                                            Margin="10,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#667EEA"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#667EEA"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5568D3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Style -->
        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="25"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.08" 
                                    BlurRadius="15" ShadowDepth="3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#DFE6E9"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#667EEA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid Style -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#F8F9FA"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" Background="#2C3E50">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="20,30,20,30">
                    <TextBlock Text="🧶 Items" 
                             FontSize="24" 
                             FontWeight="Bold" 
                             Foreground="#FFFFFF"
                             HorizontalAlignment="Center"/>
                    <TextBlock Text="Raw Materials Panel" 
                             FontSize="13" 
                             Foreground="#95A5A6"
                             HorizontalAlignment="Center"
                             Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Navigation Menu -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15,0,15,15">
                        <TextBlock Text="ACTIONS" 
                                 FontSize="11" 
                                 Foreground="#7F8C8D" 
                                 FontWeight="Bold"
                                 Margin="10,0,0,10"/>

                        <Button Style="{StaticResource SidebarButton}" 
                                Click="ShowAddItem">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="➕" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Add Item"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButton}" 
                                Click="ShowUpdateItem">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✏️" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Update Item"/>
                            </StackPanel>
                        </Button>

                        <Separator Background="#34495E" Margin="0,10,0,20"/>

                        <TextBlock Text="REPORTS" 
                                 FontSize="11" 
                                 Foreground="#7F8C8D" 
                                 FontWeight="Bold"
                                 Margin="10,0,0,10"/>

                        <Button Style="{StaticResource SidebarButton}" 
                                Click="AllItems_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="All Items"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButton}" 
                                Click="LowStockAlert_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠️" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Low Stock Alert"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButton}" 
                                Click="ItemsByPrice_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💰" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Sort by Price"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <StackPanel Grid.Row="2" Margin="15,15,15,25">
                    <Separator Background="#34495E" Margin="0,0,0,15"/>
                    <Button Content="⬅ Back to Dashboard"
                            Background="#E74C3C"
                            Foreground="#FFFFFF"
                            BorderThickness="0"
                            Padding="15,12"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="Exit_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                    VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- RIGHT CONTENT AREA -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header Section -->
            <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock x:Name="txtPageTitle" 
                             Text="Item Management Dashboard" 
                             FontSize="26" 
                             FontWeight="Bold" 
                             Foreground="#2C3E50"/>
                    <TextBlock x:Name="txtPageSubtitle"
                             Text="Manage raw materials and supplies" 
                             FontSize="13" 
                             Foreground="#7F8C8D"
                             Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Main Content Panel -->
            <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                <Grid>
                    <!-- ADD / UPDATE FORM -->
                    <ScrollViewer x:Name="ItemForm" 
                                Visibility="Collapsed" 
                                VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                            <!-- Item ID Field -->
                            <TextBlock Text="Item ID" 
                                     FontSize="13" 
                                     FontWeight="SemiBold" 
                                     Foreground="#2C3E50"
                                     Margin="0,0,0,5"/>
                            <TextBox x:Name="txtItemId" 
                                   Style="{StaticResource ModernTextBox}"
                                   IsReadOnly="True"
                                   Background="#F0F0F0"/>

                            <!-- Item Name Field -->
                            <TextBlock Text="Item Name *" 
                                     FontSize="13" 
                                     FontWeight="SemiBold" 
                                     Foreground="#2C3E50"
                                     Margin="0,0,0,5"/>
                            <TextBox x:Name="txtItemName" 
                                   Style="{StaticResource ModernTextBox}"/>

                            <!-- Description Field -->
                            <TextBlock Text="Description *" 
                                     FontSize="13" 
                                     FontWeight="SemiBold" 
                                     Foreground="#2C3E50"
                                     Margin="0,0,0,5"/>
                            <TextBox x:Name="txtDescription" 
                                   Style="{StaticResource ModernTextBox}"
                                   Height="80"
                                   TextWrapping="Wrap"
                                   AcceptsReturn="True"/>

                            <!-- Standard Unit Price Field -->
                            <TextBlock Text="Standard Unit Price (PKR) *" 
                                     FontSize="13" 
                                     FontWeight="SemiBold" 
                                     Foreground="#2C3E50"
                                     Margin="0,0,0,5"/>
                            <TextBox x:Name="txtPrice" 
                                   Style="{StaticResource ModernTextBox}"/>

                            <!-- Stock Quantity Field (Read-only for Update) -->
                            <TextBlock Text="Stock Quantity" 
                                     FontSize="13" 
                                     FontWeight="SemiBold" 
                                     Foreground="#2C3E50"
                                     Margin="0,0,0,5"/>
                            <TextBox x:Name="txtStockQty" 
                                   Style="{StaticResource ModernTextBox}"
                                   IsReadOnly="True"
                                   Background="#F0F0F0"/>

                            <!-- Info Panel -->
                            <Border Background="#FFF3CD" 
                                  BorderBrush="#FFC107"
                                  BorderThickness="1"
                                  CornerRadius="6"
                                  Padding="12"
                                  Margin="0,0,0,15"
                                  x:Name="infoPanel"
                                  Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="ℹ️ Important Information" 
                                             FontWeight="Bold"
                                             FontSize="12"
                                             Foreground="#856404"
                                             Margin="0,0,0,5"/>
                                    <TextBlock x:Name="txtInfoMessage"
                                             Text="Stock quantity cannot be updated manually. It is automatically updated when shipments arrive."
                                             FontSize="11"
                                             Foreground="#856404"
                                             TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="* Required fields" 
                                     FontSize="11" 
                                     Foreground="#7F8C8D"
                                     Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="btnSave"
                                      Content="Save Item"
                                      Style="{StaticResource PrimaryButton}"
                                      Margin="0,10,10,0"
                                      Width="150"
                                      Click="SaveItem_Click"/>

                                <Button Content="Clear Form"
                                      Background="#95A5A6"
                                      Foreground="#FFFFFF"
                                      FontSize="14"
                                      FontWeight="SemiBold"
                                      Padding="20,12"
                                      BorderThickness="0"
                                      Cursor="Hand"
                                      Margin="0,10,0,0"
                                      Width="150"
                                      Click="ClearForm_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                  CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- DATA GRID -->
                    <DataGrid x:Name="dgItems"
                            Visibility="Collapsed"
                            Style="{StaticResource ModernDataGrid}"
                            FontSize="13"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>