<Window x:Class="crochet_store.EmployeeMgnt"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Employee Management - Crochet Craft Store"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Window.Resources>
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                BorderThickness="0">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.08" 
                                                  BlurRadius="8" ShadowDepth="2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"
                                              Margin="10,0,0,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#667EEA"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#667EEA"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5568D3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="25"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.08" 
                                      BlurRadius="15" ShadowDepth="3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#DFE6E9"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#667EEA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,30,20,30">
                    <TextBlock Text="👷 Employees" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#FFFFFF"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Staff Management Panel" 
                               FontSize="13" 
                               Foreground="#95A5A6"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15,0,15,15">
                        <TextBlock Text="ACTIONS" 
                                   FontSize="11" 
                                   Foreground="#7F8C8D" 
                                   FontWeight="Bold"
                                   Margin="10,0,0,10"/>

                        <Button Name="btnAddEmployee" 
                                Style="{StaticResource SidebarButton}" 
                                Click="btnAddEmployee_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="➕" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Add New Employee"/>
                            </StackPanel>
                        </Button>

                        <Button Name="btnUpdateEmployee" 
                                Style="{StaticResource SidebarButton}" 
                                Click="btnUpdateEmployee_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✏️" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Update Employee Info"/>
                            </StackPanel>
                        </Button>

                        <Button Name="btnDeleteEmployee" 
                                Style="{StaticResource SidebarButton}" 
                                Click="btnDeleteEmployee_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑️" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Delete Employee"/>
                            </StackPanel>
                        </Button>

                        <Separator Background="#34495E" Margin="0,10,0,20"/>

                        <TextBlock Text="REPORTS" 
                                   FontSize="11" 
                                   Foreground="#7F8C8D" 
                                   FontWeight="Bold"
                                   Margin="10,0,0,10"/>

                        <Button Name="btnViewDeliveries" 
                                Style="{StaticResource SidebarButton}" 
                                Click="btnViewDeliveries_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚚" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="View Deliveries"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="15,15,15,25">
                    <Separator Background="#34495E" Margin="0,0,0,15"/>
                    <Button Content="⬅ Back to Dashboard"
                            Background="#E74C3C"
                            Foreground="#FFFFFF"
                            BorderThickness="0"
                            Padding="15,12"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="Exit_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock x:Name="txtPageTitle" 
                               Text="Employee Management Overview" 
                               FontSize="26" 
                               FontWeight="Bold" 
                               Foreground="#2C3E50"/>
                    <TextBlock x:Name="txtPageSubtitle"
                               Text="Perform staff administration tasks and view performance data." 
                               FontSize="13" 
                               Foreground="#7F8C8D"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Text="Application Output/Status Log" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="#2C3E50"
                               Margin="0,0,0,10"/>

                    <TextBox Name="txtOutput" 
                             Style="{StaticResource ModernTextBox}"
                             Height="300" 
                             VerticalScrollBarVisibility="Auto" 
                             TextWrapping="Wrap" 
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             Background="#F0F0F0"/>

                    <TextBlock Text="Use the menu on the left to perform an action."
                               FontSize="13"
                               Foreground="#7F8C8D"
                               Margin="0,20,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>