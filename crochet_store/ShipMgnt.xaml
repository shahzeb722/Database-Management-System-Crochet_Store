<Window x:Class="crochet_store.ShipMgnt"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d" 
        Title="Shipment Management - New Entry" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Window.Resources>
        <!-- Title Style -->
        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,25"/>
        </Style>

        <!-- Label Style -->
        <Style TargetType="Label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,5,0,2"/>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#DFE6E9"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#667EEA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#667EEA"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5568D3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Panel Style -->
        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="15" ShadowDepth="3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ComboBox Style -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#DFE6E9"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <Grid>
                                <ToggleButton Name="ToggleButton" 
                                              Grid.Column="2"
                                              Focusable="false"
                                              IsChecked="{Binding Path=IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              ClickMode="Press"
                                              Background="Transparent"/>
                                <ContentPresenter Margin="{TemplateBinding Padding}" 
                                                  HorizontalAlignment="Left" VerticalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="🚚 New Incoming Shipment" Style="{StaticResource TitleStyle}"/>

        <!-- Shipment Header -->
        <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,25">
            <StackPanel>
                <TextBlock Text="1. Shipment Header Details" FontSize="18" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <Label Content="Supplier"/>
                        <ComboBox x:Name="CmbSupplier" Style="{StaticResource ModernComboBox}" DisplayMemberPath="sup_name" SelectedValuePath="sup_id" Height="30"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="15,0">
                        <Label Content="Shipment Date"/>
                        <DatePicker x:Name="DpShipmentDate" SelectedDate="{x:Static sys:DateTime.Today}" Height="30"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="15,0">
                        <Label Content="Arrival Date"/>
                        <DatePicker x:Name="DpArrivalDate" SelectedDate="{x:Static sys:DateTime.Today}" Height="30"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" VerticalAlignment="Bottom" Margin="20,0,0,0">
                        <Button x:Name="BtnCreateHeader" Content="Create Header" Style="{StaticResource PrimaryButton}" Width="150" Height="30" Click="BtnCreateHeader_Click"/>
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="TxtShipmentIdDisplay" Margin="0,15,0,0" HorizontalAlignment="Right"
                           FontWeight="SemiBold" FontSize="16" Foreground="#4FACFE"
                           Text="Current Shipment ID: PENDING"/>
            </StackPanel>
        </Border>

        <!-- Item Details -->
        <Border Grid.Row="2" Style="{StaticResource CardPanel}" x:Name="ItemDetailsCard" Margin="0,0,0,25">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="2. Add Items Received" FontSize="18" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,15"/>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <Label Content="Item"/>
                        <ComboBox x:Name="CmbItem" Style="{StaticResource ModernComboBox}" DisplayMemberPath="item_name" SelectedValuePath="item_id" Height="44" Width="333"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="15,0">
                        <Label Content="Quantity Received"/>
                        <TextBox x:Name="TxtQuantity" Text="1" Height="41" Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="15,0">
                        <Label Content="Cost Per Unit (PKR)"/>
                        <TextBox x:Name="TxtCostPerUnit" Text="0.00" Height="41" Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <Button Grid.Column="3" Content="Add Item" x:Name="BtnAddItem" Style="{StaticResource PrimaryButton}" VerticalAlignment="Bottom" Width="150" Height="30" Margin="20,0,0,0" Click="BtnAddItem_Click"/>
                </Grid>

                <DataGrid x:Name="DgShipmentItems" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" MinHeight="180" CanUserAddRows="False" GridLinesVisibility="None" AlternatingRowBackground="#F8F9FA">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Item ID" Binding="{Binding item_id}" Width="Auto"/>
                        <DataGridTextColumn Header="Item Name" Binding="{Binding item_name}" Width="2*"/>
                        <DataGridTextColumn Header="Quantity" Binding="{Binding quantity_received}" Width="*"/>
                        <DataGridTextColumn Header="Cost/Unit" Binding="{Binding cost_per_unit, StringFormat='C2'}" Width="*"/>
                        <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal, StringFormat='C2'}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- Total Bill -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Text="Estimated Total Bill: " FontSize="20" VerticalAlignment="Center" Foreground="#2C3E50"/>
            <TextBlock x:Name="TxtTotalBill" Text="PKR 0.00" FontSize="32" FontWeight="Bold" Foreground="#4FACFE" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
